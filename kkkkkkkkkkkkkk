if getgenv().currentConnection then
    getgenv().currentConnection:Disconnect()
    getgenv().currentConnection = nil
end

local toggle = false

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function getClosestBall()
    local closestBall = nil
    local closestDistance = math.huge

    for _, v in pairs(workspace.Balls:GetChildren()) do
        if v:IsA("Part") then
            local ballPosition = v.Position
            local playerPosition = Player.Character.HumanoidRootPart.Position
            local distance = (ballPosition - playerPosition).Magnitude

            if distance < closestDistance then
                closestDistance = distance
                closestBall = v
            end
        end
    end

    return closestBall
end

getgenv().currentConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end

    if input.KeyCode == Enum.KeyCode.J then
        local ball = getClosestBall()

        if ball then
            toggle = not toggle

            if toggle then
                game.ReplicatedStorage.Event.MainFunction:InvokeServer(
                    "Ownership",
                    ball:GetAttribute("Index"),
                    {0, math.huge, 0},
                    {}
                )
            else
                game.ReplicatedStorage.Event.MainFunction:InvokeServer(
                    "Ownership",
                    ball:GetAttribute("Index"),
                    {0, 0, 0},
                    {}
                )
            end
        end
    end
end)
